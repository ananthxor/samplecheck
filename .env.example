# Supabase Configuration
# Get these values from: Supabase Dashboard -> Project Settings -> API

# Project URL (safe for frontend)
VITE_SUPABASE_URL=your_supabase_project_url

# Anon/Public key (safe for frontend - enforces RLS)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role key (SERVER ONLY - bypasses RLS, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_server_only

# Database password (set during project creation)
SUPABASE_DB_PASSWORD=your_database_password

# Ad serving base URL (Supabase Edge Functions)
VITE_SERVE_BASE_URL=https://your_project_ref.supabase.co/functions/v1
# Creative CDN base URL — baked into rendered_html at save time.
# Change to real CDN URL when deploying (e.g. https://cdn.scrolltoday.com)
VITE_CREATIVE_CDN_BASE=http://localhost:3005

# Dev Server Configuration
PORT=3005
VITE_PORT=3005
